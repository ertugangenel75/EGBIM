{
  "title": "Temel Metrajı (m³)",
  "description": "Yapısal temelleri toplar, hacim hesaplar, poz eşler ve XLSX/HTML raporu üretir.",
  "version": "1.0.0",
  "category": "Metraj",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "temeller",
      "op": "collect_foundations"
    },
    {
      "id": "hacim",
      "op": "foundation_volume",
      "from": "temeller"
    },
    {
      "id": "poz",
      "op": "poz_match",
      "from": "hacim"
    },
    {
      "id": "maliyet",
      "op": "calc_cost",
      "from": "poz",
      "params": {
        "quantity_field": "hacim_m3"
      }
    },
    {
      "id": "ozet",
      "op": "cost_summary",
      "from": "maliyet",
      "params": {
        "group_by": "tip"
      }
    },
    {
      "id": "rapor",
      "op": "show_table",
      "from": "ozet",
      "params": {
        "title": "Temel Metraj Özeti"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "maliyet",
      "params": {
        "sheet_name": "Temel Metraj"
      },
      "required": false
    },
    {
      "id": "html",
      "op": "export_html_report",
      "from": "maliyet",
      "params": {
        "title": "Temel Metraj Raporu"
      },
      "required": false
    }
  ],
  "tags": [
    "metraj",
    "miktar",
    "boq"
  ]
}
