{
  "title": "Beton Metrajı (m³)",
  "description": "Duvar, kolon, kiriş, döşeme beton hacimlerini hesaplar.",
  "version": "1.0.0",
  "category": "Metraj",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "kirisler",
      "op": "collect_beams"
    },
    {
      "id": "dosemeler",
      "op": "collect_floors"
    },
    {
      "id": "vol_d",
      "op": "wall_volume",
      "from": "duvarlar"
    },
    {
      "id": "vol_k",
      "op": "column_volume",
      "from": "kolonlar"
    },
    {
      "id": "vol_ki",
      "op": "beam_volume",
      "from": "kirisler"
    },
    {
      "id": "vol_f",
      "op": "floor_volume",
      "from": "dosemeler"
    },
    {
      "id": "rapor",
      "op": "show_table",
      "from": "vol_d",
      "params": {
        "title": "Duvar Beton Metrajı"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "vol_d",
      "params": {
        "sheet_name": "Duvar Beton",
        "title": "Beton Metraj"
      },
      "required": false
    },
    {
      "id": "kat_bazli",
      "op": "group_elements_by_level",
      "from": "dosemeler"
    }
  ],
  "tags": [
    "metraj",
    "miktar",
    "boq"
  ]
}
