{
  "title": "Model Eleman Özeti",
  "description": "Modeldeki tüm kategori eleman sayılarını özetler.",
  "version": "1.0.0",
  "category": "Metraj",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "checksum",
      "op": "model_checksum"
    },
    {
      "id": "goster",
      "op": "show_table",
      "from": "checksum",
      "params": {
        "title": "Model Eleman Özeti"
      }
    },
    {
      "id": "xlsx_rapor",
      "op": "export_xlsx",
      "from": "checksum",
      "params": {
        "sheet_name": "Model Eleman Özeti"
      },
      "required": false
    }
  ],
  "tags": [
    "metraj",
    "miktar",
    "boq"
  ]
}
