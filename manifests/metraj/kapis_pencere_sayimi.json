{
  "title": "Kapı/Pencere Sayımı",
  "description": "Tüm kapı ve pencereleri toplar, tip bazında sayım ve parametre listesi üretir.",
  "version": "1.0.0",
  "category": "Metraj",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "kapilar",
      "op": "collect_doors"
    },
    {
      "id": "pencereler",
      "op": "collect_windows"
    },
    {
      "id": "k_sayi",
      "op": "element_count",
      "from": "kapilar"
    },
    {
      "id": "p_sayi",
      "op": "element_count",
      "from": "pencereler"
    },
    {
      "id": "k_tipler",
      "op": "group_elements_by_type",
      "from": "kapilar"
    },
    {
      "id": "p_tipler",
      "op": "group_elements_by_type",
      "from": "pencereler"
    },
    {
      "id": "k_satirlar",
      "op": "elements_to_rows_with_params",
      "from": "kapilar",
      "params": {
        "param_names": "Genişlik,Yükseklik,Malzeme,Açılım"
      }
    },
    {
      "id": "p_satirlar",
      "op": "elements_to_rows_with_params",
      "from": "pencereler",
      "params": {
        "param_names": "Genişlik,Yükseklik,U Değeri"
      }
    },
    {
      "id": "k_rapor",
      "op": "show_table",
      "from": "k_tipler",
      "params": {
        "title": "Kapı Tip Sayımı"
      }
    },
    {
      "id": "p_rapor",
      "op": "show_table",
      "from": "p_tipler",
      "params": {
        "title": "Pencere Tip Sayımı"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "k_satirlar",
      "params": {
        "sheet_name": "Kapılar"
      },
      "required": false
    }
  ],
  "tags": [
    "metraj",
    "miktar",
    "boq"
  ]
}
