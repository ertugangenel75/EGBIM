{
  "title": "Duvar Sayımı",
  "description": "Modeldeki tüm duvarları sayar.",
  "version": "1.0.0",
  "category": "Metraj",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "sayi",
      "op": "count_items",
      "from": "duvarlar"
    },
    {
      "id": "goster",
      "op": "show_result",
      "from": "sayi",
      "params": {
        "title": "Toplam Duvar Sayısı"
      }
    },
    {
      "id": "kat_bazli",
      "op": "group_elements_by_level",
      "from": "duvarlar"
    },
    {
      "id": "satirlar",
      "op": "elements_to_rows_with_params",
      "from": "kat_bazli"
    },
    {
      "id": "xlsx_rapor",
      "op": "export_xlsx",
      "from": "satirlar",
      "params": {
        "sheet_name": "Duvar Sayımı"
      },
      "required": false
    }
  ],
  "tags": [
    "metraj",
    "miktar",
    "boq"
  ]
}
