{
  "title": "IFC Öncesi Model Doğrulama",
  "description": "IFC dışa aktarım öncesi zorunlu kontroller: parametre doluluk, sıfır hacim, odalar. Geçmeyen model IFC'ye gönderilmemeli.",
  "version": "1.0.0",
  "category": "Doğrulama",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "odalar",
      "op": "collect_rooms"
    },
    {
      "id": "qa_isim",
      "op": "param_filled_check",
      "from": "duvarlar",
      "params": {
        "param_name": "Malzeme",
        "severity": "ERROR"
      }
    },
    {
      "id": "qa_hacim",
      "op": "check_zero_volume",
      "from": "kolonlar"
    },
    {
      "id": "qa_oda",
      "op": "check_unplaced_rooms",
      "from": "odalar"
    },
    {
      "id": "birlestir",
      "op": "merge_validation_reports",
      "from_many": [
        "qa_isim",
        "qa_hacim",
        "qa_oda"
      ],
      "params": {
        "title": "IFC Öncesi Kontrol"
      }
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "birlestir"
    },
    {
      "id": "satirlar",
      "op": "validation_to_rows",
      "from": "birlestir"
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "satirlar",
      "params": {
        "sheet_name": "IFC Oncesi QA"
      },
      "required": false
    },
    {
      "id": "html",
      "op": "export_validation_report",
      "from": "birlestir",
      "params": {
        "title": "IFC Öncesi Doğrulama"
      },
      "required": false
    }
  ],
  "tags": [
    "dogrulama",
    "qa",
    "kalite",
    "validation"
  ]
}
