{
  "title": "EGBIM Zorunlu Parametreler Kontrolü",
  "description": "TR BIM / ÇŞB 2026 standartlarına göre zorunlu EGBIM paylaşımlı parametrelerin tüm kategorilerde varlık ve doluluk kontrolü.",
  "version": "1.0.0",
  "category": "Doğrulama",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "kirisler",
      "op": "collect_beams"
    },
    {
      "id": "dosemeler",
      "op": "collect_floors"
    },
    {
      "id": "temeller",
      "op": "collect_foundations"
    },
    {
      "id": "qa_d",
      "op": "param_exists_check",
      "from": "duvarlar",
      "params": {
        "param_name": "EGBIM_PozNo"
      }
    },
    {
      "id": "qa_k",
      "op": "param_exists_check",
      "from": "kolonlar",
      "params": {
        "param_name": "EGBIM_PozNo"
      }
    },
    {
      "id": "qa_ki",
      "op": "param_exists_check",
      "from": "kirisler",
      "params": {
        "param_name": "EGBIM_PozNo"
      }
    },
    {
      "id": "qa_f",
      "op": "param_exists_check",
      "from": "dosemeler",
      "params": {
        "param_name": "EGBIM_PozNo"
      }
    },
    {
      "id": "qa_t",
      "op": "param_exists_check",
      "from": "temeller",
      "params": {
        "param_name": "EGBIM_PozNo"
      }
    },
    {
      "id": "birlestir",
      "op": "merge_validation_reports",
      "from_many": [
        "qa_d",
        "qa_k",
        "qa_ki",
        "qa_f",
        "qa_t"
      ],
      "params": {
        "title": "EGBIM Zorunlu Param Kontrolü"
      }
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "birlestir"
    },
    {
      "id": "satirlar",
      "op": "validation_to_rows",
      "from": "birlestir"
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "satirlar",
      "params": {
        "sheet_name": "EGBIM Param QA"
      },
      "required": false
    },
    {
      "id": "html",
      "op": "export_validation_report",
      "from": "birlestir",
      "params": {
        "title": "EGBIM Parametre QA"
      },
      "required": false
    }
  ],
  "tags": [
    "dogrulama",
    "qa",
    "kalite",
    "validation"
  ]
}
