{
  "title": "QA: Model Uyarı Listesi",
  "category": "qa",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "uyarilar",
      "op": "qa_get_model_warnings"
    },
    {
      "id": "rapor",
      "op": "export_xlsx",
      "from": "uyarilar",
      "params": {
        "output_path": "",
        "sheet_name": "Model Uyarıları"
      }
    },
    {
      "id": "kat_ozet",
      "op": "group_elements_by_level",
      "from": "uyarilar"
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "kat_ozet"
    },
    {
      "id": "satirlar",
      "op": "validation_to_rows",
      "from": "kat_ozet"
    },
    {
      "id": "html_rapor",
      "op": "export_validation_report",
      "from": "ozet",
      "required": false,
      "params": {
        "title": "QA: Model Uyarı Listesi"
      }
    }
  ],
  "id": "m06_model_uyarilari",
  "description": "QA: Model Uyarı Listesi — 6 adımlı otomasyon iş akışı.",
  "tags": [
    "qa",
    "kalite",
    "kontrol",
    "validation"
  ]
}
