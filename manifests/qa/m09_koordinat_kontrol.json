  ],
  "steps": [
    {
      "id": "koord",
      "op": "qa_validate_coordinates"
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "koord",
      "params": {
        "title": "Koordinat Kontrolü",
        "output_path": ""
      }
    },
    {
      "id": "kat_ozet",
      "op": "group_elements_by_level",
      "from": "koord"
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "kat_ozet"
    },
    {
      "id": "satirlar",
      "op": "validation_to_rows",
      "from": "kat_ozet"
    }
  ],
  "id": "m09_koordinat_kontrol",
