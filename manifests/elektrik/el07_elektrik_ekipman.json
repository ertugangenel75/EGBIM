{
  "title": "Elektrik: Elektrik Ekipman Listesi",
  "category": "elektrik",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_ElectricalEquipment",
        "OST_LightingDevices",
        "OST_CableTray"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde elektrik elemanı bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "ekipman",
      "op": "collect_electrical_equipment"
    },
    {
      "id": "satırlar",
      "op": "elements_to_rows_with_params",
      "from": "ekipman",
      "params": {
        "param_names": [
          "Mark",
          "Family",
          "Voltage",
          "Poles",
          "Level"
        ]
      }
    },
    {
      "id": "rapor",
      "op": "export_xlsx",
      "from": "satırlar",
      "params": {
        "output_path": "",
        "sheet_name": "Elektrik Ekipman"
      }
    },
    {
      "id": "kat_bazli",
      "op": "group_elements_by_type",
      "from": "ekipman"
    },
    {
      "id": "tablo",
      "op": "show_table",
      "from": "kat_bazli",
      "params": {
        "title": "Elektrik: Elektrik Ekipman Listesi"
      }
    }
  ],
  "id": "el07_elektrik_ekipman",
  "description": "Elektrik: Elektrik Ekipman Listesi — 5 adımlı otomasyon iş akışı.",
  "tags": [
    "elektrik",
    "electrical",
    "pano",
    "kablo"
  ]
}
