{
  "title": "Elektrik: Aydınlık Düzeyi Kontrolü",
  "category": "elektrik",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_ElectricalEquipment",
        "OST_LightingDevices",
        "OST_CableTray"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde elektrik elemanı bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "armatürler",
      "op": "collect_lighting_fixtures"
    },
    {
      "id": "kontrol",
      "op": "elec_validate_lux_level",
      "from": "armatürler",
      "params": {
        "min_lux": 300
      }
    },
    {
      "id": "satırlar",
      "op": "validation_to_rows",
      "from": "kontrol"
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "satırlar",
      "params": {
        "title": "Lux Kontrolü",
        "output_path": ""
      }
    },
    {
      "id": "kat_ozet",
      "op": "group_elements_by_level",
      "from": "kontrol"
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "kat_ozet"
    }
  ],
  "id": "el04_lux_kontrol",
  "description": "Elektrik: Aydınlık Düzeyi Kontrolü — 6 adımlı otomasyon iş akışı.",
  "tags": [
    "elektrik",
    "electrical",
    "pano",
    "kablo"
  ]
}
