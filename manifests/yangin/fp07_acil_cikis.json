{
  "title": "Yangın: Acil Çıkış Aydınlatması",
  "category": "yangin",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_FireAlarmDevices",
        "OST_Sprinklers",
        "OST_PipeCurves"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yangın elemanı bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "odalar",
      "op": "collect_rooms"
    },
    {
      "id": "armatürler",
      "op": "collect_lighting_fixtures"
    },
    {
      "id": "kontrol",
      "op": "elec_check_emergency_lighting",
      "from": "odalar",
      "params": {
        "fixtures": "$armatürler",
        "emergency_keywords": [
          "acil",
          "emergency",
          "exit",
          "çıkış",
          "kaçış"
        ]
      }
    },
    {
      "id": "satırlar",
      "op": "validation_to_rows",
      "from": "kontrol"
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "satırlar",
      "params": {
        "title": "Acil Çıkış Aydınlatma",
        "output_path": ""
      }
    },
    {
      "id": "kat_ozet",
      "op": "group_elements_by_level",
      "from": "kontrol"
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "kat_ozet"
    }
  ],
  "id": "fp07_acil_cikis",
  "description": "Yangın: Acil Çıkış Aydınlatması — 7 adımlı otomasyon iş akışı.",
  "tags": [
    "yangin",
    "fire",
    "sprinkler",
    "nfpa"
  ]
}
