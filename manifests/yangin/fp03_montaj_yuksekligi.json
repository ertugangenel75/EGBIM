{
  "title": "Yangın: FA Cihaz Montaj Yüksekliği",
  "category": "yangin",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_FireAlarmDevices",
        "OST_Sprinklers",
        "OST_PipeCurves"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yangın elemanı bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "cihazlar",
      "op": "collect_fire_alarm_devices"
    },
    {
      "id": "kontrol",
      "op": "fa_validate_mounting_height",
      "from": "cihazlar",
      "params": {
        "min_aff_mm": 2000,
        "max_aff_mm": 2400,
        "device_filter": "Horn|Strobe|Siren|Hörn"
      }
    },
    {
      "id": "satırlar",
      "op": "validation_to_rows",
      "from": "kontrol"
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "satırlar",
      "params": {
        "title": "FA Montaj Yüksekliği",
        "output_path": ""
      }
    },
    {
      "id": "kat_ozet",
      "op": "group_elements_by_level",
      "from": "kontrol"
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "kat_ozet"
    }
  ],
  "id": "fp03_montaj_yuksekligi",
  "description": "Yangın: FA Cihaz Montaj Yüksekliği — 6 adımlı otomasyon iş akışı.",
  "tags": [
    "yangin",
    "fire",
    "sprinkler",
    "nfpa"
  ]
}
