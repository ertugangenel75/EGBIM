{
  "title": "CSV'den Model Eleman Güncelleme",
  "description": "CSV dosyasından okunan verileri model elemanlarına yazar. Farklı bir sistemden gelen verileri Revit'e aktarmak için kullanılır.",
  "category": "ETL Veri",
  "version": "1.0.0",
  "tags": [
    "csv",
    "import",
    "güncelleme",
    "parametre",
    "etl",
    "veri aktarım"
  ],
  "transaction_policy": "atomic",
  "steps": [
    {
      "id": "s01_csv",
      "op": "csv_read",
      "params": {
        "file_path": "EG_Data_Import.csv",
        "delimiter": ",",
        "has_header": true
      }
    },
    {
      "id": "s02_schema",
      "op": "table_validate_schema",
      "from": "s01_csv",
      "params": {
        "required_fields": [
          "ElementId",
          "TR_PozNo",
          "TR_WBS_Kodu"
        ],
        "optional_fields": [
          "TR_IlerlemeYuzdesi",
          "TR_Notlar"
        ]
      }
    },
    {
      "id": "s03_tum",
      "op": "collect_multi",
      "params": {
        "categories": [
          "OST_Walls",
          "OST_StructuralColumns",
          "OST_StructuralFraming",
          "OST_Floors"
        ]
      }
    },
    {
      "id": "s04_satirlar",
      "op": "elements_to_rows_with_params",
      "from": "s03_tum",
      "params": {
        "param_names": [
          "ElementId",
          "Category",
          "Level"
        ]
      }
    },
    {
      "id": "s05_join",
      "op": "join_rows",
      "from_many": [
        "s04_satirlar",
        "s01_csv"
      ],
      "params": {
        "key_field": "ElementId"
      }
    },
    {
      "id": "s06_poz_yaz",
      "op": "write_param_from_rows",
      "from": "s05_join",
      "params": {
        "param_name": "TR_PozNo",
        "value_field": "TR_PozNo"
      }
    },
    {
      "id": "s07_wbs_yaz",
      "op": "write_param_from_rows",
      "from": "s05_join",
      "params": {
        "param_name": "TR_WBS_Kodu",
        "value_field": "TR_WBS_Kodu"
      }
    },
    {
      "id": "s08_html",
      "op": "export_html_report",
      "from": "s05_join",
      "params": {
        "title": "CSV İmport Raporu"
      }
    },
    {
      "id": "s09_goster",
      "op": "show_result",
      "from": "s06_poz_yaz",
      "params": {
        "title": "İmport Tamamlandı"
      }
    }
  ]
}