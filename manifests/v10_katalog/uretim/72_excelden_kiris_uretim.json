{
  "title": "Excel'den Kiriş Üretimi",
  "description": "CSV başlangıç-bitiş koordinat tablosundan yapısal kirişleri üretir. Noktalardan eğri oluşturur, onay alır ve kirişleri yerleştirir. trace_key ile idempotent.",
  "category": "Üretim",
  "version": "1.1.0",
  "tags": [
    "üretim",
    "kiriş",
    "yapısal",
    "excel",
    "otomasyon",
    "create"
  ],
  "transaction_policy": "preview",
  "steps": [
    {
      "id": "s01_oku",
      "op": "csv_read",
      "params": {
        "file_path": "$INPUT:file_path:Kiriş koordinat dosyası (CSV):*.csv",
        "delimiter": ",",
        "has_header": true
      }
    },
    {
      "id": "s02_baslangic",
      "op": "table_to_points",
      "from": "s01_oku",
      "params": {
        "x_field": "x1",
        "y_field": "y1",
        "z_field": "z1",
        "unit": "mm"
      }
    },
    {
      "id": "s03_bitis",
      "op": "table_to_points",
      "from": "s01_oku",
      "params": {
        "x_field": "x2",
        "y_field": "y2",
        "z_field": "z2",
        "unit": "mm"
      }
    },
    {
      "id": "s04_egri",
      "op": "list_zip",
      "from": "s02_baslangic",
      "inputs": {
        "second_key": "s03_bitis"
      }
    },
    {
      "id": "s05_onay",
      "op": "preview_gate",
      "from": "s04_egri",
      "params": {
        "title": "Kiriş Üretimi — Eğrilere kiriş yerleştirilsin mi?"
      }
    },
    {
      "id": "s06_uret",
      "op": "create_beam_by_curve",
      "from": "s04_egri",
      "condition": "$s05_onay == confirmed",
      "params": {
        "family_name": "$INPUT:family_type:Kiriş ailesi ve tipi>>family_name",
        "type_name": "$INPUT:family_type:Kiriş ailesi ve tipi>>type_name",
        "level_name": "$INPUT:level:Kiriş seviyesi",
        "offset_mm": 0
      }
    },
    {
      "id": "s07_iz",
      "op": "trace_write",
      "from": "s06_uret",
      "condition": "$s05_onay == confirmed",
      "params": {
        "trace_key": "uretim_kiris_excel"
      }
    },
    {
      "id": "s08_satirlar",
      "op": "elements_to_rows_with_params",
      "from": "s06_uret",
      "condition": "$s05_onay == confirmed",
      "params": {
        "param_names": [
          "Family",
          "Type",
          "Reference Level",
          "Length"
        ]
      }
    },
    {
      "id": "s09_excel",
      "op": "export_xlsx",
      "from": "s08_satirlar",
      "condition": "$s05_onay == confirmed",
      "params": {
        "file_path": "EG_Uretilen_Kirisler.xlsx",
        "sheet_name": "Kirişler",
        "title": "Üretilen Kirişler"
      }
    },
    {
      "id": "s10_goster",
      "op": "show_result",
      "from": "s06_uret",
      "params": {
        "title": "Kiriş Üretimi Tamamlandı"
      }
    }
  ]
}
