{
  "title": "Duvar Maliyet Hesabı",
  "description": "Duvarları toplar, poz eşler, maliyet hesaplar, WBS'e bağlar.",
  "version": "1.0.0",
  "category": "Maliyet",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "sinifla",
      "op": "classify_elements",
      "from": "duvarlar"
    },
    {
      "id": "poz",
      "op": "poz_match",
      "from": "duvarlar"
    },
    {
      "id": "kalip",
      "op": "kalip_wall",
      "from": "duvarlar"
    },
    {
      "id": "maliyet",
      "op": "calc_cost",
      "from": "poz"
    },
    {
      "id": "ozet",
      "op": "cost_summary",
      "from": "maliyet"
    },
    {
      "id": "rapor",
      "op": "show_table",
      "from": "ozet",
      "params": {
        "title": "Duvar Maliyet Özeti"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "maliyet",
      "params": {
        "sheet_name": "Maliyet",
        "title": "Duvar Maliyet"
      },
      "required": false
    },
    {
      "id": "html",
      "op": "export_html_report",
      "from": "maliyet",
      "params": {
        "title": "Duvar Maliyet Raporu"
      },
      "required": false
    }
  ],
  "tags": [
    "maliyet",
    "cost",
    "poz",
    "fiyat"
  ]
}
