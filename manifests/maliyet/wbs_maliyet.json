{
  "title": "WBS Maliyet Raporu",
  "description": "Duvar ve kolonları toplar, poz eşler, WBS kodu atar, maliyet raporu üretir.",
  "version": "1.0.0",
  "category": "Maliyet",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "wbs_map",
      "op": "load_wbs_mapping"
    },
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "poz_d",
      "op": "poz_match",
      "from": "duvarlar"
    },
    {
      "id": "poz_k",
      "op": "poz_match",
      "from": "kolonlar"
    },
    {
      "id": "maliyet_d",
      "op": "calc_cost",
      "from": "poz_d"
    },
    {
      "id": "maliyet_k",
      "op": "calc_cost",
      "from": "poz_k"
    },
    {
      "id": "birlestir",
      "op": "merge_rows",
      "from_many": [
        "maliyet_d",
        "maliyet_k"
      ]
    },
    {
      "id": "wbs",
      "op": "assign_wbs_code",
      "from": "birlestir"
    },
    {
      "id": "wbs_link",
      "op": "link_quantity_to_wbs",
      "from": "wbs"
    },
    {
      "id": "rapor",
      "op": "show_table",
      "from": "wbs_link",
      "params": {
        "title": "WBS Maliyet"
      }
    },
    {
      "id": "html",
      "op": "export_wbs_report",
      "from": "wbs_link",
      "params": {
        "title": "WBS Maliyet Raporu"
      }
    }
  ],
  "tags": [
    "maliyet",
    "cost",
    "poz",
    "fiyat"
  ]
}
