{
  "title": "Kalıp Maliyet Analizi (m²)",
  "description": "Duvar, kolon ve döşeme kalıp yüzeylerini hesaplar, kalıp poz fiyatlarıyla maliyet çıkarır ve kat özetini raporlar.",
  "version": "1.0.0",
  "category": "Maliyet",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "dosemeler",
      "op": "collect_floors"
    },
    {
      "id": "kalip_d",
      "op": "kalip_wall",
      "from": "duvarlar"
    },
    {
      "id": "kalip_k",
      "op": "kalip_column",
      "from": "kolonlar"
    },
    {
      "id": "kalip_f",
      "op": "kalip_floor",
      "from": "dosemeler"
    },
    {
      "id": "poz_d",
      "op": "poz_match",
      "from": "kalip_d"
    },
    {
      "id": "poz_k",
      "op": "poz_match",
      "from": "kalip_k"
    },
    {
      "id": "poz_f",
      "op": "poz_match",
      "from": "kalip_f"
    },
    {
      "id": "mal_d",
      "op": "calc_cost",
      "from": "poz_d",
      "params": {
        "quantity_field": "kalip_m2"
      }
    },
    {
      "id": "mal_k",
      "op": "calc_cost",
      "from": "poz_k",
      "params": {
        "quantity_field": "kalip_m2"
      }
    },
    {
      "id": "mal_f",
      "op": "calc_cost",
      "from": "poz_f",
      "params": {
        "quantity_field": "kalip_m2"
      }
    },
    {
      "id": "birlesik",
      "op": "merge_lists",
      "from_many": [
        "mal_d",
        "mal_k",
        "mal_f"
      ]
    },
    {
      "id": "ozet",
      "op": "kalip_summary",
      "from": "birlesik"
    },
    {
      "id": "kat_ozet",
      "op": "cost_by_level",
      "from": "birlesik"
    },
    {
      "id": "rapor",
      "op": "show_table",
      "from": "kat_ozet",
      "params": {
        "title": "Kalıp Kat Maliyet"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "birlesik",
      "params": {
        "sheet_name": "Kalıp Maliyet"
      },
      "required": false
    },
    {
      "id": "html",
      "op": "export_html_report",
      "from": "birlesik",
      "params": {
        "title": "Kalıp Maliyet Analizi"
      },
      "required": false
    }
  ],
  "tags": [
    "maliyet",
    "cost",
    "poz",
    "fiyat"
  ]
}
