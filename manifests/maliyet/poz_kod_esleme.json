{
  "title": "ÇŞB 2026 Poz Kodu ile Doğrudan Eşleme",
  "description": "Elemanlarda zaten EGBIM_PozNo parametresi dolu ise bu poz kodları üzerinden ÇŞB 2026 birim fiyatları çeker ve maliyet hesaplar.",
  "version": "1.0.0",
  "category": "Maliyet",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "birlesik",
      "op": "merge_lists",
      "from_many": [
        "duvarlar",
        "kolonlar"
      ]
    },
    {
      "id": "satirlar",
      "op": "elements_to_rows_with_params",
      "from": "birlesik",
      "params": {
        "param_names": "EGBIM_PozNo,Mark"
      }
    },
    {
      "id": "poz",
      "op": "poz_match_by_code",
      "from": "satirlar",
      "params": {
        "poz_code_field": "EGBIM_PozNo"
      }
    },
    {
      "id": "hacim",
      "op": "element_volume",
      "from": "birlesik"
    },
    {
      "id": "maliyet",
      "op": "calc_cost",
      "from": "poz",
      "params": {
        "quantity_field": "hacim_m3"
      }
    },
    {
      "id": "ozet",
      "op": "cost_summary",
      "from": "maliyet",
      "params": {
        "group_by": "poz_no"
      }
    },
    {
      "id": "rapor",
      "op": "show_table",
      "from": "ozet",
      "params": {
        "title": "Poz Kodu Maliyet Özeti"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "maliyet",
      "params": {
        "sheet_name": "Poz Maliyet"
      },
      "required": false
    }
  ],
  "tags": [
    "maliyet",
    "cost",
    "poz",
    "fiyat"
  ]
}
