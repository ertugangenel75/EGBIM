{
  "title": "Kat Bazlı Maliyet Raporu",
  "description": "Tüm yapısal elemanların maliyetini kat bazında gruplar. Nakit akışı planlama ve kat bazlı bütçe analizi için.",
  "version": "1.0.0",
  "category": "Maliyet",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "kirisler",
      "op": "collect_beams"
    },
    {
      "id": "dosemeler",
      "op": "collect_floors"
    },
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "vol_k",
      "op": "column_volume",
      "from": "kolonlar"
    },
    {
      "id": "vol_ki",
      "op": "beam_volume",
      "from": "kirisler"
    },
    {
      "id": "vol_d",
      "op": "floor_volume",
      "from": "dosemeler"
    },
    {
      "id": "vol_du",
      "op": "wall_volume",
      "from": "duvarlar"
    },
    {
      "id": "poz_k",
      "op": "poz_match",
      "from": "vol_k"
    },
    {
      "id": "poz_ki",
      "op": "poz_match",
      "from": "vol_ki"
    },
    {
      "id": "poz_d",
      "op": "poz_match",
      "from": "vol_d"
    },
    {
      "id": "poz_du",
      "op": "poz_match",
      "from": "vol_du"
    },
    {
      "id": "mal_k",
      "op": "calc_cost",
      "from": "poz_k",
      "params": {
        "quantity_field": "hacim_m3"
      }
    },
    {
      "id": "mal_ki",
      "op": "calc_cost",
      "from": "poz_ki",
      "params": {
        "quantity_field": "hacim_m3"
      }
    },
    {
      "id": "mal_d",
      "op": "calc_cost",
      "from": "poz_d",
      "params": {
        "quantity_field": "hacim_m3"
      }
    },
    {
      "id": "mal_du",
      "op": "calc_cost",
      "from": "poz_du",
      "params": {
        "quantity_field": "hacim_m3"
      }
    },
    {
      "id": "birlesik",
      "op": "merge_lists",
      "from_many": [
        "mal_k",
        "mal_ki",
        "mal_d",
        "mal_du"
      ]
    },
    {
      "id": "kat_ozet",
      "op": "cost_by_level",
      "from": "birlesik"
    },
    {
      "id": "rapor",
      "op": "show_table",
      "from": "kat_ozet",
      "params": {
        "title": "Kat Bazlı Maliyet"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "kat_ozet",
      "params": {
        "sheet_name": "Kat Maliyet"
      },
      "required": false
    },
    {
      "id": "html",
      "op": "export_html_report",
      "from": "kat_ozet",
      "params": {
        "title": "Kat Bazlı Maliyet Raporu"
      },
      "required": false
    }
  ],
  "tags": [
    "maliyet",
    "cost",
    "poz",
    "fiyat"
  ]
}
