{
  "title": "ETL: Tam Maliyet Zinciri",
  "category": "etl",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "REGISTRY_KEY_EXISTS",
      "key": "project_data",
      "on_fail": "WARN",
      "message": "Proje verisi yüklü değil"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "hepsi",
      "op": "collect_multi",
      "params": {
        "categories": [
          "OST_Walls",
          "OST_Floors",
          "OST_Columns",
          "OST_StructuralFraming",
          "OST_Foundations"
        ]
      }
    },
    {
      "id": "wbs",
      "op": "assign_wbs_code",
      "from": "hepsi"
    },
    {
      "id": "poz",
      "op": "poz_match",
      "from": "wbs",
      "params": {
        "data_path": "poz/csb_poz_2026.json"
      }
    },
    {
      "id": "rayic",
      "op": "load_rayic",
      "params": {
        "rayic_path": "poz/rayic_2026.json"
      }
    },
    {
      "id": "maliyet",
      "op": "calc_cost",
      "from": "poz"
    },
    {
      "id": "ozet",
      "op": "cost_summary",
      "from": "maliyet"
    },
    {
      "id": "rapor",
      "op": "export_xlsx",
      "from": "maliyet",
      "params": {
        "output_path": "",
        "sheet_name": "Maliyet"
      }
    },
    {
      "id": "tablo",
      "op": "show_table",
      "from": "ozet",
      "params": {
        "title": "ETL: Tam Maliyet Zinciri"
      }
    },
    {
      "id": "satirlar",
      "op": "elements_to_rows_with_params",
      "from": "hepsi"
    }
  ],
  "id": "d08_maliyet_zinciri",
  "description": "ETL: Tam Maliyet Zinciri — 10 adımlı otomasyon iş akışı.",
  "tags": [
    "etl",
    "veri",
    "excel",
    "pipeline"
  ]
}
