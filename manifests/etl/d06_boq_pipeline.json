{
  "title": "ETL: BOQ Metraj → Maliyet Pipeline",
  "category": "etl",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "REGISTRY_KEY_EXISTS",
      "key": "project_data",
      "on_fail": "WARN",
      "message": "Proje verisi yüklü değil"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "kirisler",
      "op": "collect_beams"
    },
    {
      "id": "dosemeler",
      "op": "collect_floors"
    },
    {
      "id": "hepsi",
      "op": "merge_lists",
      "from_many": [
        "duvarlar",
        "kolonlar",
        "kirisler",
        "dosemeler"
      ]
    },
    {
      "id": "sinifla",
      "op": "classify_elements",
      "from": "hepsi"
    },
    {
      "id": "poz",
      "op": "poz_match",
      "from": "sinifla",
      "params": {
        "data_path": "poz/csb_poz_2026.json"
      }
    },
    {
      "id": "maliyet",
      "op": "calc_cost",
      "from": "poz"
    },
    {
      "id": "rapor",
      "op": "export_xlsx",
      "from": "maliyet",
      "params": {
        "output_path": "",
        "sheet_name": "BOQ"
      }
    },
    {
      "id": "tablo",
      "op": "show_table",
      "from": "maliyet",
      "params": {
        "title": "ETL: BOQ Metraj → Maliyet Pipeline"
      }
    },
    {
      "id": "satirlar",
      "op": "elements_to_rows_with_params",
      "from": "dosemeler"
    }
  ],
  "id": "d06_boq_pipeline",
  "description": "ETL: BOQ Metraj → Maliyet Pipeline — 12 adımlı otomasyon iş akışı.",
  "tags": [
    "etl",
    "veri",
    "excel",
    "pipeline"
  ]
}
