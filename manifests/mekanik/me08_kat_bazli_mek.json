{
  "title": "MEP-Mek: Kat Bazlı Mekanik Özet",
  "category": "mekanik",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_DuctCurves",
        "OST_MechanicalEquipment"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde mekanik eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "kanallar",
      "op": "collect_ducts"
    },
    {
      "id": "kat_grp",
      "op": "group_elements_by_level",
      "from": "kanallar"
    },
    {
      "id": "satırlar",
      "op": "elements_to_rows_with_params",
      "from": "kanallar",
      "params": {
        "param_names": [
          "Level",
          "System Name",
          "Length"
        ]
      }
    },
    {
      "id": "rapor",
      "op": "export_xlsx",
      "from": "satırlar",
      "params": {
        "output_path": "",
        "sheet_name": "Kat Mekanik"
      }
    },
    {
      "id": "tablo",
      "op": "show_table",
      "from": "kat_grp",
      "params": {
        "title": "MEP-Mek: Kat Bazlı Mekanik Özet"
      }
    }
  ],
  "id": "me08_kat_bazli_mek",
  "description": "MEP-Mek: Kat Bazlı Mekanik Özet — 5 adımlı otomasyon iş akışı.",
  "tags": [
    "mekanik",
    "hvac",
    "mep"
  ]
}
