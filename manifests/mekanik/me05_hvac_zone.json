{
  "title": "MEP-Mek: HVAC Zone Ataması",
  "category": "mekanik",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_DuctCurves",
        "OST_MechanicalEquipment"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde mekanik eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "mekanlar",
      "op": "collect_air_terminals"
    },
    {
      "id": "kontrol",
      "op": "mep_validate_space_hvac_zone",
      "from": "mekanlar"
    },
    {
      "id": "satırlar",
      "op": "validation_to_rows",
      "from": "kontrol"
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "satırlar",
      "params": {
        "title": "HVAC Zone",
        "output_path": ""
      }
    },
    {
      "id": "kat_ozet",
      "op": "group_elements_by_level",
      "from": "kontrol"
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "kat_ozet"
    }
  ],
  "id": "me05_hvac_zone",
  "description": "MEP-Mek: HVAC Zone Ataması — 6 adımlı otomasyon iş akışı.",
  "tags": [
    "mekanik",
    "hvac",
    "mep"
  ]
}
