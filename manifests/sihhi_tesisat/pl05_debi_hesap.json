{
  "title": "Sıhhi: Debi Hesabı",
  "category": "sihhi_tesisat",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_PipeCurves",
        "OST_PlumbingFixtures"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde sıhhi tesisat elemanı bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "armatürler",
      "op": "collect_plumbing_fixtures"
    },
    {
      "id": "debi",
      "op": "plumbing_calc_flow_rate",
      "from": "armatürler"
    },
    {
      "id": "rapor",
      "op": "export_xlsx",
      "from": "debi",
      "params": {
        "output_path": "",
        "sheet_name": "Debi"
      }
    },
    {
      "id": "kat_bazli",
      "op": "group_elements_by_type",
      "from": "armatürler"
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "kat_bazli"
    },
    {
      "id": "satirlar",
      "op": "validation_to_rows",
      "from": "kat_bazli"
    }
  ],
  "id": "pl05_debi_hesap",
  "description": "Sıhhi: Debi Hesabı — 6 adımlı otomasyon iş akışı.",
  "tags": [
    "sihhi",
    "tesisat",
    "boru",
    "plumbing"
  ]
}
