{
  "title": "Kalıp Tam Rapor (Duvar+Kolon+Döşeme)",
  "description": "Tüm kalıp elemanlarını hesaplar, kat bazında özetler, poz eşler ve ÇŞB 2026 birim fiyatlarıyla maliyet çıkarır.",
  "version": "1.0.0",
  "category": "Kalıp",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_StructuralColumns",
        "OST_StructuralFraming",
        "OST_Walls",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "dosemeler",
      "op": "collect_floors"
    },
    {
      "id": "kalip_d",
      "op": "kalip_wall",
      "from": "duvarlar"
    },
    {
      "id": "kalip_k",
      "op": "kalip_column",
      "from": "kolonlar"
    },
    {
      "id": "kalip_f",
      "op": "kalip_floor",
      "from": "dosemeler"
    },
    {
      "id": "birlesik",
      "op": "merge_lists",
      "from_many": [
        "kalip_d",
        "kalip_k",
        "kalip_f"
      ]
    },
    {
      "id": "ozet",
      "op": "kalip_summary",
      "from": "birlesik"
    },
    {
      "id": "poz",
      "op": "poz_match",
      "from": "birlesik"
    },
    {
      "id": "maliyet",
      "op": "calc_cost",
      "from": "poz",
      "params": {
        "quantity_field": "kalip_m2"
      }
    },
    {
      "id": "kat_ozet",
      "op": "cost_by_level",
      "from": "maliyet"
    },
    {
      "id": "r_ozet",
      "op": "show_table",
      "from": "kat_ozet",
      "params": {
        "title": "Kalıp Kat Bazlı"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "birlesik",
      "params": {
        "sheet_name": "Kalıp Tam"
      },
      "required": false
    },
    {
      "id": "html",
      "op": "export_html_report",
      "from": "birlesik",
      "params": {
        "title": "Kalıp Tam Rapor"
      },
      "required": false
    }
  ],
  "tags": [
    "kalip",
    "formwork",
    "metraj"
  ]
}
