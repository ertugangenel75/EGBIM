{
  "title": "Yapısal: Donatı Parametre Kontrolü",
  "category": "yapisal",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_StructuralColumns",
        "OST_StructuralFraming",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "donatı",
      "op": "collect_rebar"
    },
    {
      "id": "kontrol",
      "op": "validate_required_params",
      "from": "donatı",
      "params": {
        "required_params": [
          "Bar Diameter",
          "Rebar Number",
          "Host Mark"
        ]
      }
    },
    {
      "id": "satırlar",
      "op": "validation_to_rows",
      "from": "kontrol"
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "satırlar",
      "params": {
        "title": "Donatı Parametre",
        "output_path": ""
      }
    },
    {
      "id": "kat_ozet",
      "op": "group_elements_by_level",
      "from": "kontrol"
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "kat_ozet"
    }
  ],
  "id": "s06_donati_param",
  "description": "Yapısal: Donatı Parametre Kontrolü — 6 adımlı otomasyon iş akışı.",
  "tags": [
    "yapisal",
    "structural",
    "ts500",
    "tbdy"
  ]
}
