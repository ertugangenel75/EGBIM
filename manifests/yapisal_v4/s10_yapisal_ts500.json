{
  "title": "Yapısal: TS500 Donatı Bindirme/Ankraj",
  "category": "yapisal",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_StructuralColumns",
        "OST_StructuralFraming",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "donatı",
      "op": "collect_rebar"
    },
    {
      "id": "kontrol",
      "op": "validate_rebar_ts500",
      "from": "donatı"
    },
    {
      "id": "satırlar",
      "op": "validation_to_rows",
      "from": "kontrol"
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "satırlar",
      "params": {
        "output_path": "",
        "sheet_name": "TS500 Donatı"
      }
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "satırlar",
      "params": {
        "title": "TS500 Donatı Kontrolü",
        "output_path": ""
      }
    },
    {
      "id": "kat_ozet",
      "op": "group_elements_by_level",
      "from": "kontrol"
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "kat_ozet"
    }
  ],
  "id": "s10_yapisal_ts500",
  "standard": "TS500",
  "description": "Yapısal: TS500 Donatı Bindirme/Ankraj — 7 adımlı otomasyon iş akışı.",
  "tags": [
    "yapisal",
    "structural",
    "ts500",
    "tbdy"
  ]
}
