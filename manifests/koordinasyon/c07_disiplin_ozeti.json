{
  "title": "Koordinasyon: Disiplin Bazlı Özet",
  "category": "koordinasyon",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_DuctCurves",
        "OST_PipeCurves"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "kanallar",
      "op": "collect_ducts"
    },
    {
      "id": "borular",
      "op": "collect_pipes"
    },
    {
      "id": "kablo",
      "op": "collect_cable_trays"
    },
    {
      "id": "yapisal",
      "op": "collect_beams"
    },
    {
      "id": "k_uzun",
      "op": "mep_total_length",
      "from": "kanallar"
    },
    {
      "id": "b_uzun",
      "op": "mep_total_length",
      "from": "borular"
    },
    {
      "id": "kablo_uzun",
      "op": "mep_total_length",
      "from": "kablo"
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "k_uzun",
      "params": {
        "title": "Disiplin Özeti",
        "output_path": ""
      }
    },
    {
      "id": "tablo",
      "op": "show_table",
      "from": "kablo_uzun",
      "params": {
        "title": "Koordinasyon: Disiplin Bazlı Özet"
      }
    },
    {
      "id": "satirlar",
      "op": "elements_to_rows_with_params",
      "from": "yapisal"
    }
  ],
  "id": "c07_disiplin_ozeti",
  "description": "Koordinasyon: Disiplin Bazlı Özet — 10 adımlı otomasyon iş akışı.",
