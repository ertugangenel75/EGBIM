{
  "title": "Koordinasyon: Yangın Geçiş Mühürü",
  "category": "koordinasyon",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_DuctCurves",
        "OST_PipeCurves"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "borular",
      "op": "collect_pipes"
    },
    {
      "id": "kanallar",
      "op": "collect_ducts"
    },
    {
      "id": "hepsi",
      "op": "merge_lists",
      "from_many": [
        "borular",
        "kanallar"
      ]
    },
    {
      "id": "kontrol",
      "op": "coord_validate_penetration_firestop",
      "from": "hepsi"
    },
    {
      "id": "satırlar",
      "op": "validation_to_rows",
      "from": "kontrol"
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "satırlar",
      "params": {
        "title": "Yangın Mühürü",
        "output_path": ""
      }
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "kontrol"
    }
  ],
  "id": "c03_yangin_muhur",
  "description": "Koordinasyon: Yangın Geçiş Mühürü — 7 adımlı otomasyon iş akışı.",
  "tags": [
    "koordinasyon",
    "clash",
    "cakisma",
    "bim"
  ]
}
