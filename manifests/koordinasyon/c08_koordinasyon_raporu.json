{
  "title": "Koordinasyon: Tam Koordinasyon Raporu",
  "category": "koordinasyon",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_DuctCurves",
        "OST_PipeCurves"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "kanallar",
      "op": "collect_ducts"
    },
    {
      "id": "kirisler",
      "op": "collect_beams"
    },
    {
      "id": "cakisma",
      "op": "coord_check_clearance",
      "from": "kanallar",
      "params": {
        "secondary_elements": "$kirisler",
        "min_clearance_mm": 50
      }
    },
    {
      "id": "muhur_boru",
      "op": "collect_pipes"
    },
    {
      "id": "muhur",
      "op": "coord_validate_penetration_firestop",
      "from": "muhur_boru"
    },
    {
      "id": "m_satirlar",
      "op": "validation_to_rows",
      "from": "muhur"
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "m_satirlar",
      "params": {
        "title": "Tam Koordinasyon",
        "output_path": ""
      }
    },
    {
      "id": "birlesik",
      "op": "merge_validation_reports",
      "from_many": [
        "cakisma",
        "muhur"
      ],
      "params": {
        "title": "Koordinasyon: Tam Koordinasyon Raporu"
      }
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "birlesik"
    }
  ],
  "id": "c08_koordinasyon_raporu",
  "description": "Koordinasyon: Tam Koordinasyon Raporu — 9 adımlı otomasyon iş akışı.",
  "tags": [
    "koordinasyon",
    "clash",
    "cakisma",
    "bim"
  ]
}
