{
  "title": "Kablo Tava & İletken Raporu",
  "description": "Kablo taşıyıcı elemanları (cable tray, conduit) toplar, sistem ve kat bazında uzunluk metrajı üretir.",
  "version": "1.0.0",
  "category": "MEP",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_DuctCurves",
        "OST_PipeCurves",
        "OST_CableTray"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde MEP elemanı bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "kablo_tava",
      "op": "collect_cable_trays"
    },
    {
      "id": "iletken",
      "op": "collect_conduits"
    },
    {
      "id": "kt_sys",
      "op": "mep_by_system",
      "from": "kablo_tava"
    },
    {
      "id": "il_sys",
      "op": "mep_by_system",
      "from": "iletken"
    },
    {
      "id": "kt_toplam",
      "op": "mep_total_length",
      "from": "kablo_tava"
    },
    {
      "id": "il_toplam",
      "op": "mep_total_length",
      "from": "iletken"
    },
    {
      "id": "birlesik",
      "op": "merge_lists",
      "from_many": [
        "kt_sys",
        "il_sys"
      ]
    },
    {
      "id": "rapor",
      "op": "show_table",
      "from": "birlesik",
      "params": {
        "title": "Kablo Tava & İletken Özeti"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "birlesik",
      "params": {
        "sheet_name": "Kablo Tava"
      },
      "required": false
    }
  ],
  "tags": [
    "mep",
    "tesisat",
    "mekanik"
  ]
}
