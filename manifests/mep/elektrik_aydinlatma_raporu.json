{
  "title": "Elektrik & Aydınlatma Raporu",
  "description": "Aydınlatma armatürleri, elektrik ekipmanları, prizler ve anahtarları toplar, kat ve tip bazında sayım ve metraj üretir.",
  "version": "1.0.0",
  "category": "MEP",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_DuctCurves",
        "OST_PipeCurves",
        "OST_CableTray"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde MEP elemanı bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "armaturler",
      "op": "collect_lighting_fixtures"
    },
    {
      "id": "cihazlar",
      "op": "collect_lighting_devices"
    },
    {
      "id": "ekipman",
      "op": "collect_electrical_equipment"
    },
    {
      "id": "priz",
      "op": "collect_electrical_fixtures"
    },
    {
      "id": "a_tipler",
      "op": "group_elements_by_type",
      "from": "armaturler"
    },
    {
      "id": "e_tipler",
      "op": "group_elements_by_type",
      "from": "ekipman"
    },
    {
      "id": "a_kat",
      "op": "group_elements_by_level",
      "from": "armaturler"
    },
    {
      "id": "a_sayi",
      "op": "element_count",
      "from": "armaturler"
    },
    {
      "id": "e_sayi",
      "op": "element_count",
      "from": "ekipman"
    },
    {
      "id": "r_arm",
      "op": "show_table",
      "from": "a_tipler",
      "params": {
        "title": "Aydınlatma Armatür Tip Sayımı"
      }
    },
    {
      "id": "r_kat",
      "op": "show_table",
      "from": "a_kat",
      "params": {
        "title": "Kat Bazlı Armatür"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "a_tipler",
      "params": {
        "sheet_name": "Aydınlatma"
      },
      "required": false
    }
  ],
  "tags": [
    "mep",
    "tesisat",
    "mekanik"
  ]
}
