{
  "title": "Mekanik Ekipman & Sıhhi Tesisat Raporu",
  "description": "Mekanik ekipmanlar ve sıhhi tesisat elemanlarını toplar, kat bazında gruplar ve sprinkler sayımı ekler.",
  "version": "1.0.0",
  "category": "MEP",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_DuctCurves",
        "OST_PipeCurves",
        "OST_CableTray"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde MEP elemanı bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "mek_ekip",
      "op": "collect_mechanical_equipment"
    },
    {
      "id": "sihhitesisat",
      "op": "collect_plumbing_fixtures"
    },
    {
      "id": "sprinkler",
      "op": "collect_sprinklers"
    },
    {
      "id": "yangın_al",
      "op": "collect_fire_alarm_devices"
    },
    {
      "id": "m_tipler",
      "op": "group_elements_by_type",
      "from": "mek_ekip"
    },
    {
      "id": "s_tipler",
      "op": "group_elements_by_type",
      "from": "sihhitesisat"
    },
    {
      "id": "m_kat",
      "op": "group_elements_by_level",
      "from": "mek_ekip"
    },
    {
      "id": "spr_sayi",
      "op": "element_count",
      "from": "sprinkler"
    },
    {
      "id": "ya_sayi",
      "op": "element_count",
      "from": "yangın_al"
    },
    {
      "id": "r_mek",
      "op": "show_table",
      "from": "m_tipler",
      "params": {
        "title": "Mekanik Ekipman Tip"
      }
    },
    {
      "id": "r_sih",
      "op": "show_table",
      "from": "s_tipler",
      "params": {
        "title": "Sıhhi Tesisat Tip"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "m_tipler",
      "params": {
        "sheet_name": "Mekanik Ekipman"
      },
      "required": false
    }
  ],
  "tags": [
    "mep",
    "tesisat",
    "mekanik"
  ]
}
