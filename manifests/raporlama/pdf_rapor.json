{
  "title": "PDF Metraj Raporu",
  "description": "Kalıp metrajını PDF olarak dışa aktarır (HTML print).",
  "version": "1.0.0",
  "category": "Raporlama",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "kalip",
      "op": "kalip_wall",
      "from": "duvarlar"
    },
    {
      "id": "ozet",
      "op": "kalip_summary",
      "from": "kalip"
    },
    {
      "id": "poz",
      "op": "poz_match",
      "from": "duvarlar"
    },
    {
      "id": "maliyet",
      "op": "calc_cost",
      "from": "poz"
    },
    {
      "id": "pdf",
      "op": "export_pdf",
      "from": "maliyet",
      "params": {
        "title": "Kalıp Maliyet PDF Raporu"
      }
    },
    {
      "id": "satirlar",
      "op": "elements_to_rows_with_params",
      "from": "duvarlar"
    }
  ],
  "tags": [
    "rapor",
    "report",
    "export"
  ]
}
