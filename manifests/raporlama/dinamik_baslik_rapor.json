{
  "title": "Dinamik Başlıklı Rapor ($varName param örneği)",
  "description": "Proje adını okur, sonraki adımda $proje_adi olarak rapor başlığında kullanır.",
  "version": "1.0.0",
  "category": "Raporlama",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Walls",
        "OST_StructuralColumns",
        "OST_Floors"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "sistem",
      "op": "system_info"
    },
    {
      "id": "duvarlar",
      "op": "collect_walls",
      "cache": true
    },
    {
      "id": "hacim",
      "op": "element_volume",
      "from": "duvarlar"
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "hacim",
      "params": {
        "title": "$sistem"
      }
    },
    {
      "id": "kat_bazli",
      "op": "group_elements_by_level",
      "from": "duvarlar"
    },
    {
      "id": "tablo",
      "op": "show_table",
      "from": "kat_bazli",
      "params": {
        "title": "Dinamik Başlıklı Rapor ($varName param örneği)"
      }
    },
    {
      "id": "satirlar",
      "op": "elements_to_rows_with_params",
      "from": "kat_bazli"
    }
  ],
  "tags": [
    "rapor",
    "report",
    "export"
  ]
}
