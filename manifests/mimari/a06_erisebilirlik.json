{
  "title": "Mimari: Erişilebilirlik Kontrolü",
  "category": "mimari",
  "version": "1.0.0",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_Rooms",
        "OST_Doors",
        "OST_Windows"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde mimari eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "kapilar",
      "op": "collect_doors"
    },
    {
      "id": "kontrol",
      "op": "arch_validate_accessibility",
      "from": "kapilar",
      "params": {
        "min_width_mm": 850
      }
    },
    {
      "id": "satırlar",
      "op": "validation_to_rows",
      "from": "kontrol"
    },
    {
      "id": "rapor",
      "op": "export_html_report",
      "from": "satırlar",
      "params": {
        "title": "Erişilebilirlik Raporu",
        "output_path": ""
      }
    },
    {
      "id": "kat_bazli",
      "op": "group_elements_by_level",
      "from": "kapilar"
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "kat_bazli"
    }
  ],
  "id": "a06_erisebilirlik",
  "description": "Mimari: Erişilebilirlik Kontrolü — 6 adımlı otomasyon iş akışı.",
  "tags": [
    "mimari",
    "architecture",
    "oda"
  ]
}
