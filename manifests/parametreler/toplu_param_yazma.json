{
  "title": "Toplu Parametre Güncelleme",
  "description": "Mevcut parametre değerlerini okur, WBS kodu atar ve EGBIM_PozNo parametresini tüm elemanlara toplu yazar.",
  "version": "1.0.0",
  "category": "Parametre",
  "pre_checks": [
    {
      "type": "REGISTRY_KEY_EXISTS",
      "key": "project_data",
      "on_fail": "WARN",
      "message": "Proje verisi yüklü değil"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "duvarlar",
      "op": "collect_walls"
    },
    {
      "id": "birlesik",
      "op": "merge_lists",
      "from_many": [
        "kolonlar",
        "duvarlar"
      ]
    },
    {
      "id": "wbs",
      "op": "classify_by_wbs",
      "from": "birlesik"
    },
    {
      "id": "poz",
      "op": "poz_match",
      "from": "wbs"
    },
    {
      "id": "yaz",
      "op": "write_param_from_rows",
      "from": "poz",
      "params": {
        "param_name": "EGBIM_PozNo",
        "value_field": "poz_no"
      }
    },
    {
      "id": "dogrula",
      "op": "param_filled_check",
      "from": "birlesik",
      "params": {
        "param_name": "EGBIM_PozNo",
        "severity": "ERROR"
      }
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "dogrula"
    },
    {
      "id": "satirlar",
      "op": "validation_to_rows",
      "from": "dogrula"
    },
    {
      "id": "html_rapor",
      "op": "export_validation_report",
      "from": "satirlar",
      "params": {
        "title": "Toplu Parametre Güncelleme"
      },
      "required": false
    },
    {
      "id": "xlsx_rapor",
      "op": "export_xlsx",
      "from": "satirlar",
      "params": {
        "sheet_name": "Toplu Parametre Güncelleme"
      },
      "required": false
    }
  ],
  "tags": [
    "parametre",
    "shared_param",
    "tr_bim"
  ]
}
