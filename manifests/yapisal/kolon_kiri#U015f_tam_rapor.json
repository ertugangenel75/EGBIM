{
  "title": "Kolon & Kiriş Tam Rapor",
  "description": "Kolonlar ve kirişleri kat bazında gruplar, hacim + yükseklik/uzunluk, donatı ağırlığı ve ÇŞB 2026 poz bilgilerini tek raporda sunar.",
  "version": "1.0.0",
  "category": "Yapısal",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_StructuralColumns",
        "OST_StructuralFraming",
        "OST_StructuralFoundation"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "poz_yukle",
      "op": "load_poz_data",
      "required": false
    },
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "kirisler",
      "op": "collect_beams"
    },
    {
      "id": "donatı",
      "op": "collect_rebar"
    },
    {
      "id": "kol_hac",
      "op": "column_volume",
      "from": "kolonlar"
    },
    {
      "id": "kir_hac",
      "op": "beam_volume",
      "from": "kirisler"
    },
    {
      "id": "kol_yuk",
      "op": "column_height",
      "from": "kolonlar"
    },
    {
      "id": "don_ozet",
      "op": "rebar_summary_by_level",
      "from": "donatı"
    },
    {
      "id": "poz_k",
      "op": "poz_match",
      "from": "kol_hac"
    },
    {
      "id": "poz_ki",
      "op": "poz_match",
      "from": "kir_hac"
    },
    {
      "id": "mal_k",
      "op": "calc_cost",
      "from": "poz_k",
      "params": {
        "quantity_field": "hacim_m3"
      }
    },
    {
      "id": "mal_ki",
      "op": "calc_cost",
      "from": "poz_ki",
      "params": {
        "quantity_field": "hacim_m3"
      }
    },
    {
      "id": "r_kol",
      "op": "show_table",
      "from": "kol_hac",
      "params": {
        "title": "Kolon Beton (m³)"
      }
    },
    {
      "id": "r_kir",
      "op": "show_table",
      "from": "kir_hac",
      "params": {
        "title": "Kiriş Beton (m³)"
      }
    },
    {
      "id": "r_don",
      "op": "show_table",
      "from": "don_ozet",
      "params": {
        "title": "Donatı Kat Özeti (kg)"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "mal_k",
      "params": {
        "sheet_name": "Kolon-Kiriş"
      },
      "required": false
    },
    {
      "id": "kat_bazli",
      "op": "group_elements_by_level",
      "from": "donatı"
    }
  ],
  "tags": [
    "yapisal",
    "structural",
    "ts500",
    "tbdy"
  ]
}
