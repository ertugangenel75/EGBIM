{
  "title": "Kolon Metraj ve Sınıflandırma",
  "description": "Kolonları toplar, sınıflandırır, hacim hesaplar.",
  "version": "1.0.0",
  "category": "Yapısal",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_StructuralColumns",
        "OST_StructuralFraming",
        "OST_StructuralFoundation"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "sinifla",
      "op": "classify_elements",
      "from": "kolonlar"
    },
    {
      "id": "hacim",
      "op": "column_volume",
      "from": "kolonlar"
    },
    {
      "id": "toplam",
      "op": "sum_field",
      "from": "hacim",
      "params": {
        "field": "hacim_m3"
      }
    },
    {
      "id": "rapor",
      "op": "show_table",
      "from": "hacim",
      "params": {
        "title": "Kolon Hacim Raporu"
      }
    },
    {
      "id": "xlsx",
      "op": "export_xlsx",
      "from": "hacim",
      "params": {
        "sheet_name": "Kolon Metraj"
      },
      "required": false
    },
    {
      "id": "kat_bazli",
      "op": "group_elements_by_level",
      "from": "kolonlar"
    }
  ],
  "tags": [
    "yapisal",
    "structural",
    "ts500",
    "tbdy"
  ]
}
