{
  "title": "Kolon QA Doğrulama",
  "description": "Kolonları toplar, sınıflandırır ve QA kurallarına göre doğrular.",
  "version": "1.0.0",
  "category": "Yapısal",
  "pre_checks": [
    {
      "type": "MODEL_HAS_ELEMENTS",
      "categories": [
        "OST_StructuralColumns",
        "OST_StructuralFraming",
        "OST_StructuralFoundation"
      ],
      "min_count": 1,
      "on_fail": "ABORT",
      "message": "Modelde yapısal eleman bulunamadı"
    }
  ],
  "steps": [
    {
      "id": "kolonlar",
      "op": "collect_columns"
    },
    {
      "id": "siniflandir",
      "op": "classify_elements",
      "from": "kolonlar"
    },
    {
      "id": "qa",
      "op": "validate_qa",
      "from": "siniflandir"
    },
    {
      "id": "ozet",
      "op": "validation_summary",
      "from": "qa"
    },
    {
      "id": "goster",
      "op": "show_table",
      "from": "qa",
      "params": {
        "title": "Kolon QA Sonuçları"
      }
    },
    {
      "id": "kat_ozet",
      "op": "group_elements_by_level",
      "from": "qa"
    },
    {
      "id": "html_rapor",
      "op": "export_validation_report",
      "from": "kat_ozet",
      "params": {
        "title": "Kolon QA Doğrulama"
      },
      "required": false
    },
    {
      "id": "xlsx_rapor",
      "op": "export_xlsx",
      "from": "kat_ozet",
      "params": {
        "sheet_name": "Kolon QA Doğrulama"
      },
      "required": false
    }
  ],
  "tags": [
    "yapisal",
    "structural",
    "ts500",
    "tbdy"
  ]
}
