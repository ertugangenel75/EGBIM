{
  "id": "s15_tam_yapisal_hesap",
  "title": "Yapısal: Tam Sistem Hesap Pipeline (10 Op)",
  "description": "Yapısal tam ön hesap: kolon bindirme → perde filiz → ankraj → beton QA → kiriş h/L → perde narinlik → döşeme kalınlık → temel basınç → bulon QA → kalıp seçimi. Tek manifest ile tüm yapısal ön hesaplar.",
  "category": "YAPISAL",
  "version": "1.0",
  "tags": [
    "yapisal","bindirme","ankraj","beton","kiris","perde","doseme",
    "temel","bulon","kalip","ts500","tbdy","aisc","pipeline"
  ],
  "transaction_policy": "none",
  "steps": [
    {
      "id": "s01_kolon_lap",
      "op": "struct_rebar_lap_kolon",
      "description": "1) Kolon filiz/bindirme boyu",
      "inputs": {
        "cap_mm": "$INPUT:cap_mm:16", "beton_sinifi": "$INPUT:beton_sinifi:C25",
        "celik_sinifi": "B420C", "kolon_l_d_orani": 3.0,
        "deprem_bolgesi": true, "basinc_mi": true
      }
    },
    {
      "id": "s02_perde_lap",
      "op": "struct_rebar_lap_perde",
      "description": "2) Perde filiz boyu",
      "inputs": {
        "cap_mm": "$INPUT:cap_mm:12", "beton_sinifi": "$INPUT:beton_sinifi:C25",
        "donati_yonu": "dusey", "perde_kalinlik_mm": 200, "perde_yukseklik_mm": 3000
      }
    },
    {
      "id": "s03_ankraj",
      "op": "struct_rebar_anchorage",
      "description": "3) Ankraj boyu",
      "inputs": {
        "cap_mm": "$INPUT:cap_mm:16", "beton_sinifi": "$INPUT:beton_sinifi:C25",
        "ankraj_tipi": "$INPUT:ankraj_tipi:duz", "basinc_mi": false
      }
    },
    {
      "id": "s04_beton",
      "op": "struct_concrete_class_qa",
      "description": "4) Beton sınıfı QA",
      "inputs": {
        "beton_sinifi": "$INPUT:beton_sinifi:C25",
        "kullanim_yeri": "deprem_yuksek", "deprem_bolgesi": true, "eleman_tipi": "kolon"
      }
    },
    {
      "id": "s05_kiris",
      "op": "struct_beam_depth_ratio",
      "description": "5) Kiriş h/L oranı",
      "inputs": { "kiriş_tipi": "surekli", "min_genislik_mm": 250 }
    },
    {
      "id": "s06_perde_nar",
      "op": "struct_wall_slenderness",
      "description": "6) Perde narinlik h/t ≤ 25",
      "inputs": { "max_narinlik": 25.0, "min_kalinlik_mm": 200 }
    },
    {
      "id": "s07_doseme",
      "op": "struct_slab_thickness",
      "description": "7) Döşeme minimum kalınlık",
      "inputs": {
        "aciklik_mm": "$INPUT:aciklik_mm:4000",
        "doseme_tipi": "$INPUT:doseme_tipi:cift_yonlu",
        "mevcut_kalinlik_mm": "$INPUT:mevcut_kalinlik_mm:120"
      }
    },
    {
      "id": "s08_temel",
      "op": "struct_foundation_bearing",
      "description": "8) Temel taban basıncı",
      "inputs": {
        "eksenel_yuk_kn": "$INPUT:eksenel_yuk_kn:500",
        "temel_genislik_m": "$INPUT:temel_genislik_m:2.0",
        "temel_uzunluk_m": "$INPUT:temel_uzunluk_m:2.0",
        "zemin_emniyet_kpa": 150.0, "moment_knm": 0
      }
    },
    {
      "id": "s09_bulon",
      "op": "struct_steel_bolt_type_check",
      "description": "9) Çelik bulon tipi QA",
      "inputs": {
        "bulon_tipi": "$INPUT:bulon_tipi:N",
        "baglanti_turu": "kesme_kritik", "titresim_var": false, "dinamik_yuk": false
      }
    },
    {
      "id": "s10_kalip",
      "op": "struct_formwork_type_select",
      "description": "10) Kalıp sistemi seçimi",
      "inputs": {
        "bina_tipi": "$INPUT:bina_tipi:konut",
        "kat_sayisi": "$INPUT:kat_sayisi:10",
        "tekrar_oncelik": false, "hiz_oncelik": false
      }
    },
    {
      "id": "s11_rapor",
      "op": "export_html_report",
      "description": "11) Tam rapor",
      "inputs": {
        "output_path": "$INPUT:output_path:C:/EGBIM_Output/tam_yapisal_hesap.html",
        "title": "Yapısal Tam Sistem Hesap Raporu (10 Op)"
      }
    }
  ]
}
