<Window x:Class="EGBIMOTO.Addin.UI.ManifestGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EGBIMOTO — Manifest Üretici"
        Height="760" Width="920"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Window.Resources>
        <SolidColorBrush x:Key="BgPanel"      Color="#2A2A3E"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#BD93F9"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#50FA7B"/>
        <SolidColorBrush x:Key="AccentRed"    Color="#FF5555"/>
        <SolidColorBrush x:Key="AccentWarn"   Color="#FFB86C"/>
        <SolidColorBrush x:Key="AccentCyan"   Color="#8BE9FD"/>
        <SolidColorBrush x:Key="TextMain"     Color="#F8F8F2"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#9090A8"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#44445A"/>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.32"/></Trigger>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Opacity" Value="0.82"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="110"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Başlık -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="⚡  Manifest Üretici" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentPurple}"/>
                <TextBlock Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0">
                    <Run Text="MOD 1:"/><Run Text=" ⚡ Pattern" Foreground="{StaticResource AccentCyan}"/>
                    <Run Text=" — API'siz, ~100ms, %65-85 doğruluk   |   "/>
                    <Run Text="MOD 2:"/><Run Text=" 🤖 AI" Foreground="{StaticResource AccentPurple}"/>
                    <Run Text=" — API key gerekli, 3-8s, %90-95 doğruluk"/>
                </TextBlock>
            </StackPanel>
        </Grid>
        <!-- API Key -->
        <Border Grid.Row="1" Background="{StaticResource BgPanel}" CornerRadius="8" Padding="10,8"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="API KEY" Foreground="{StaticResource TextMuted}" FontSize="9" FontWeight="Bold"/>
                    <TextBlock Text="(opsiyonel)" Foreground="{StaticResource TextMuted}" FontSize="9"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#1E1E2E" CornerRadius="5" Padding="8,4"
                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                    <PasswordBox x:Name="pwdApiKey" Background="Transparent" BorderThickness="0"
                                 Foreground="{StaticResource TextMain}" PasswordChanged="PwdApiKey_Changed"/>
                </Border>
                <TextBlock Grid.Column="2" x:Name="txtApiKeyHint" Text="— Pattern modu"
                           Foreground="{StaticResource AccentWarn}" VerticalAlignment="Center"
                           FontSize="11" Margin="10,0,0,0"/>
            </Grid>
        </Border>
        <!-- İstek -->
        <Border Grid.Row="2" Background="{StaticResource BgPanel}" CornerRadius="8" Padding="10"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="NE YAPMAK İSTİYORSUN?" Foreground="{StaticResource AccentPurple}"
                           FontSize="9" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox Grid.Row="1" x:Name="txtRequest" Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource TextMain}" FontSize="13" TextWrapping="Wrap"
                         AcceptsReturn="True" TextChanged="TxtRequest_TextChanged"
                         Text="Kolonları topla, kalıp hesabı yap, poz eşle, kat bazlı maliyet özeti, Excel rapor üret"/>
            </Grid>
        </Border>
        <!-- Örnek butonlar -->
        <WrapPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Örnekler: " Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" FontSize="11" Margin="0,0,6,0"/>
            <Button Style="{StaticResource Btn}" Background="#2A3050" Foreground="{StaticResource TextMuted}"
                    FontSize="10" Margin="0,0,4,4" Click="BtnExample_Click"
                    Tag="Duvarları topla, kat bazlı alan hesabı yap, poz eşle, Excel raporu üret">Duvar Metraj</Button>
            <Button Style="{StaticResource Btn}" Background="#2A3050" Foreground="{StaticResource TextMuted}"
                    FontSize="10" Margin="0,0,4,4" Click="BtnExample_Click"
                    Tag="Kolonları topla, kalıp hesabı yap, poz eşle, ÇŞB 2026 maliyet, kat ve poz bazlı özet">Kolon Kalıp+Maliyet</Button>
            <Button Style="{StaticResource Btn}" Background="#2A3050" Foreground="{StaticResource TextMuted}"
                    FontSize="10" Margin="0,0,4,4" Click="BtnExample_Click"
                    Tag="EGBIM_PozNo parametresini tüm yapısal elemanlarda kontrol et, boş olanları listele, HTML ve Excel rapor">Param QA</Button>
            <Button Style="{StaticResource Btn}" Background="#2A3050" Foreground="{StaticResource TextMuted}"
                    FontSize="10" Margin="0,0,4,4" Click="BtnExample_Click"
                    Tag="Tüm MEP borularını topla, sistem bazlı uzunluk özeti, kat bazlı grupla, Excel rapor">MEP Boru</Button>
            <Button Style="{StaticResource Btn}" Background="#2A3050" Foreground="{StaticResource TextMuted}"
                    FontSize="10" Margin="0,0,4,4" Click="BtnExample_Click"
                    Tag="TS500 bindirme boyu hesapla: ø12/C25, ø16/C30, ø20/C30. Ankraj boylarını da hesapla">TS500 Bindirme</Button>
            <Button Style="{StaticResource Btn}" Background="#2A3050" Foreground="{StaticResource TextMuted}"
                    FontSize="10" Margin="0,0,4,4" Click="BtnExample_Click"
                    Tag="Odaları topla, yerleştirilmemiş ve çakışan odaları bul, alan kontrolü yap, HTML rapor">Oda QA</Button>
        </WrapPanel>
        <!-- JSON Önizleme -->
        <Border Grid.Row="4" Background="{StaticResource BgPanel}" CornerRadius="8" Padding="10"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="ÜRETİLEN JSON  (düzenleyebilirsiniz)"
                           Foreground="{StaticResource AccentPurple}" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="txtJsonPreview" Background="Transparent" BorderThickness="0"
                             Foreground="#50FA7B" FontFamily="Cascadia Code,Consolas,monospace"
                             FontSize="12" TextWrapping="Wrap" IsReadOnly="False"
                             Text="// ⚡ Pattern veya 🤖 AI butonuna bas..."/>
                </ScrollViewer>
            </Grid>
        </Border>
        <!-- Validasyon -->
        <TextBlock Grid.Row="5" x:Name="txtValidationInfo" Foreground="{StaticResource TextMuted}"
                   FontSize="10" Margin="0,0,0,5" TextWrapping="Wrap"/>
        <!-- Progress -->
        <ProgressBar Grid.Row="6" x:Name="progressBar" Height="3" Margin="0,0,0,8"
                     Background="#2A2A3E" Foreground="{StaticResource AccentPurple}"
                     IsIndeterminate="True" Visibility="Collapsed"/>
        <!-- Butonlar -->
        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="txtStatus" Foreground="{StaticResource TextMuted}"
                       VerticalAlignment="Center" FontSize="11" Text="İstek yaz → ⚡ Pattern veya 🤖 AI seç"/>
            <Button Grid.Column="1" x:Name="btnPattern" Content="⚡  Pattern" Style="{StaticResource Btn}"
                    Background="{StaticResource AccentCyan}" Foreground="#1E1E2E" IsEnabled="False"
                    Click="BtnPattern_Click" ToolTip="API'siz — anahtar kelime analizi (%65-85 doğruluk)"/>
            <Button Grid.Column="3" x:Name="btnAI" Content="🤖  AI" Style="{StaticResource Btn}"
                    Background="{StaticResource AccentPurple}" Foreground="#1E1E2E" IsEnabled="False"
                    Click="BtnAI_Click" ToolTip="Claude API — doğal dil anlayışı (%90-95 doğruluk)"/>
            <Button Grid.Column="5" x:Name="btnSave" Content="💾  Kaydet" Style="{StaticResource Btn}"
                    Background="#44445A" Foreground="{StaticResource TextMain}" IsEnabled="False" Click="BtnSave_Click"/>
            <Button Grid.Column="7" Content="Kapat" Style="{StaticResource Btn}"
                    Background="{StaticResource BgPanel}" Foreground="{StaticResource TextMuted}" Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>
