<Window x:Class="EGBIMOTO.Addin.UI.PreviewGateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="EGBIMOTO — Önizleme"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Buton Stilleri -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="#4CAF50"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#388E3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#2E7D32"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background"   Value="#F44336"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D32F2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>     <!-- Header -->
            <RowDefinition Height="*"/>      <!-- WebView2 -->
            <RowDefinition Height="Auto"/>   <!-- Stats bar -->
            <RowDefinition Height="64"/>     <!-- Footer / butonlar -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#13131F">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo / ikon -->
                <TextBlock Grid.Column="0" Text="⬡" FontSize="22"
                           Foreground="#5B9BD5" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <!-- Başlık -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TitleText" Text="Önizleme"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock x:Name="SubtitleText" Text=""
                               FontSize="11" Foreground="#888"/>
                </StackPanel>

                <!-- Element sayısı rozeti -->
                <Border Grid.Column="2" Background="#2A2A3E" CornerRadius="12"
                        Padding="12,4" VerticalAlignment="Center">
                    <TextBlock x:Name="CountBadge" Text="0 eleman"
                               FontSize="12" Foreground="#5B9BD5"/>
                </Border>
            </Grid>
        </Border>

        <!-- ── Three.js WebView2 ─────────────────────────────────────────── -->
        <wv2:WebView2 x:Name="WebView"
                      Grid.Row="1"
                      DefaultBackgroundColor="Transparent"/>

        <!-- ── Stats bar ─────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#13131F" Padding="16,6">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Hidden">
                <WrapPanel x:Name="StatsPanel" Orientation="Horizontal"/>
            </ScrollViewer>
        </Border>

        <!-- ── Uyarılar (gizli, varsa görünür) ──────────────────────────── -->
        <Border x:Name="WarningBorder" Grid.Row="2" Background="#3E2000"
                Padding="16,6" Visibility="Collapsed">
            <TextBlock x:Name="WarningText" Foreground="#FFA726"
                       FontSize="11" TextWrapping="Wrap"/>
        </Border>

        <!-- ── Footer / Butonlar ─────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#13131F">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Sol: ipucu -->
                <TextBlock Grid.Column="0"
                           Text="Sol tık: döndür  |  Sağ tık: kaydır  |  Scroll: zoom"
                           Foreground="#555" FontSize="11"
                           VerticalAlignment="Center"/>

                <!-- Kamera sıfırla -->
                <Button Grid.Column="1" x:Name="ResetCameraBtn"
                        Content="↺ Kamera" Click="ResetCamera_Click"
                        Background="#2A2A3E" Foreground="#AAA"
                        BorderThickness="0" Padding="14,8"
                        Cursor="Hand" FontSize="12"/>

                <!-- İptal -->
                <Button Grid.Column="3" x:Name="CancelBtn"
                        Content="✕  İptal" Click="Cancel_Click"
                        Style="{StaticResource DangerBtn}"/>

                <!-- Onayla -->
                <Button Grid.Column="5" x:Name="ConfirmBtn"
                        Content="✓  Onayla ve Uygula" Click="Confirm_Click"
                        Style="{StaticResource PrimaryBtn}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
