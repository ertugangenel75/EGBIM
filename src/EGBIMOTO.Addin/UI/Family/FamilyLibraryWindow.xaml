<Window x:Class="EGBIMOTO.Addin.UI.FamilyLibrary.FamilyLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EGBIMOTO — Aile Kütüphanesi"
        Height="720" Width="1040"
        MinHeight="480" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">
    <Window.Resources>
        <SolidColorBrush x:Key="BgPanel"     Color="#2A2A3E"/>
        <SolidColorBrush x:Key="BgHover"     Color="#313150"/>
        <SolidColorBrush x:Key="AccentBlue"  Color="#7B9FFF"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#50FA7B"/>
        <SolidColorBrush x:Key="AccentWarn"  Color="#FFB86C"/>
        <SolidColorBrush x:Key="AccentRed"   Color="#FF5555"/>
        <SolidColorBrush x:Key="TextMain"    Color="#F8F8F2"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#9090A8"/>
        <SolidColorBrush x:Key="BorderColor" Color="#44445A"/>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource BgPanel}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMain}"/>
            <Setter Property="Padding"         Value="14,7"/>
            <Setter Property="Margin"          Value="0,0,8,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="FamilyItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="8,6"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Margin="0,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{StaticResource BgHover}"/></Trigger>
                            <Trigger Property="IsSelected"  Value="True"><Setter Property="Background" Value="#3D3D6B"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Klasör seçimi + tarama -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FolderPathBox" Grid.Column="0" IsReadOnly="True"
                     Background="{StaticResource BgPanel}" Foreground="{StaticResource TextMain}"
                     BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                     Padding="8,6" VerticalContentAlignment="Center"
                     Text="Klasör seçilmedi — 'Klasör Seç' ile aile kütüphanesi kökünü belirleyin."/>
            <Button x:Name="PickFolderBtn" Grid.Column="1" Style="{StaticResource ActionBtn}"
                    Content="📁 Klasör Seç" Click="PickFolder_Click" Margin="8,0,8,0"/>
            <Button x:Name="ScanBtn" Grid.Column="2" Style="{StaticResource PrimaryBtn}"
                    Content="🔍 Tara" Click="Scan_Click" IsEnabled="False" Margin="0,0,8,0"/>
            <Button x:Name="CancelBtn" Grid.Column="3" Style="{StaticResource ActionBtn}"
                    Content="✗ İptal" Click="Cancel_Click" IsEnabled="False"/>
        </Grid>

        <!-- İlerleme -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="ScanProgress" Grid.Column="0" Height="6" Minimum="0" Maximum="100"
                         Background="{StaticResource BgPanel}" Foreground="{StaticResource AccentBlue}"
                         BorderThickness="0"/>
            <TextBlock x:Name="ProgressText" Grid.Column="1" Margin="10,0,0,0"
                       Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
        </Grid>

        <!-- Master/Detail -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgPanel}" CornerRadius="6" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox x:Name="FilterBox" Grid.Row="0" Margin="0,0,0,6"
                             Background="#232335" Foreground="{StaticResource TextMain}"
                             BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                             Padding="6,5" TextChanged="FilterBox_TextChanged"
                             Tag="Aile adı veya kategori ara..."/>
                    <ListBox x:Name="FamilyList" Grid.Row="1" Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource FamilyItem}"
                             SelectionChanged="FamilyList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Margin="2,2,8,0"
                                            VerticalAlignment="Top" Background="{Binding StatusColor}"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding FamilyName}" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Text="{Binding CategoryName}" Foreground="{StaticResource TextMuted}" FontSize="10.5"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <Border Grid.Column="2" Background="{StaticResource BgPanel}" CornerRadius="6" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="DetailPanel">
                        <TextBlock x:Name="DetailEmptyText" Text="Soldan bir aile seçin."
                                   Foreground="{StaticResource TextMuted}"/>
                        <StackPanel x:Name="DetailContent" Visibility="Collapsed">
                            <TextBlock x:Name="DetailTitleText" FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextMain}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="DetailPathText" FontSize="10.5"
                                       Foreground="{StaticResource TextMuted}" Margin="0,2,0,10" TextWrapping="Wrap"/>
                            <ItemsControl x:Name="DetailParamList"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Alt özet + dışa aktarım -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="SummaryText" Grid.Column="0"
                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="ExportCsvBtn" Style="{StaticResource ActionBtn}"
                        Content="📄 CSV'ye Aktar" Click="ExportCsv_Click" IsEnabled="False"/>
                <Button x:Name="CloseBtn" Style="{StaticResource ActionBtn}"
                        Content="Kapat" Click="Close_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
